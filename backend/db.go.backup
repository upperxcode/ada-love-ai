t	_, err = s.db.Exec(`INSERT INTO workspace_agents (workspace_id, agent_id, enabled) VALUES (?, ?, ?)`,
			ws.id, a.id, a.enabled)
			ws.id, a.ID, a.Enabled)
		if err != nil {
			return err
		}
t_, err = s.db.Exec(`DELETE FROM workspace_skills WHERE workspace_id = ?`, ws.id)

	_, err = s.db.Exec(`DELETE FROM workspace_skills WHERE workspace_id = ?`, ws.id)
	if err != nil {
		return err
	}
t	_, err = s.db.Exec(`INSERT INTO workspace_skills (workspace_id, skill_id, enabled) VALUES (?, ?, ?)`,
			ws.id, sk.ID, sk.Enabled)
		_, err = s.db.Exec(`INSERT INTO workspace_skills (workspace_id, skill_id, enabled) VALUES (?, ?, ?)`,
			sk.ID, sk.ID, sk.Enabled)
		if err != nil {
			return err
t_, err = s.db.Exec(`DELETE FROM workspace_tools WHERE workspace_id = ?`, ws.id)
	}

	_, err = s.db.Exec(`DELETE FROM workspace_tools WHERE workspace_id = ?`, ws.id)
	if err != nil {
