#!/usr/bin/fish

cd (dirname (status -f))/..

set blue (set_color blue)
set green (set_color green)
set red (set_color red)
set yellow (set_color yellow)
set purple (set_color magenta)
set normal (set_color normal)

function show_menu
    echo ""
    echo "$purple" "┌──────────────────────────────────────────────────┐"
    echo "$purple" "│          🤖 ADA-LOVE-AI - DASHBOARD UI           │"
    echo "$purple" "└──────────────────────────────────────────────────┘"
    echo "$normal"
    echo "$blue 1$normal 🌐 Wails Dev (React Hot-Reload)"
    echo "$blue 2$normal 🔧 Wails Build (Produção)"
    echo "$blue 3$normal 📦 Build Frontend"
    echo "$blue 4$normal 🛠️  Instalar Dependências"
    echo "$blue 5$normal 🧹 Limpar Cache"
    echo "$red 6$normal ❌ Sair"
    echo ""
end

while true
    show_menu
    read -p 'echo -e "$yellow 👉 Escolha uma opção (1-6): $normal"' opt

    switch "$opt"
        case 1
            echo "$blue" "[INFO] Iniciando Wails Dev (React Hot-Reload)..."
            echo "$yellow" "[INFO] Certifique-se de que o frontend tem as dependências instaladas: cd frontend && npm install"
            wails dev -tags "webkit2_41"
        case 2
            echo "$green" "[BUILD] Gerando binário Wails Produção..."
            mkdir -p bin
            cd frontend && npm run build && cd ..
            wails build -tags "webkit2_41" -o bin/ada-love-ai
        case 3
            echo "$green" "[BUILD] Compilando Frontend React..."
            cd frontend && npm run build && cd ..
        case 4
            echo "$green" "[INSTALL] Instalando dependências..."
            cd frontend && npm install && cd ..
            go mod tidy
        case 5
            echo "$yellow" "[CLEAN] Limpando cache..."
            go clean -cache
            rm -rf bin/ frontend/dist/
        case 6
            break
    end
end
